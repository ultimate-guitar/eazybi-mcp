# ---- eazyBI for Jira Cloud ------------------------------------------------
# Public API host for the eazyBI add-on on Atlassian Cloud is fixed.
EAZYBI_BASE_URL=https://aod.eazybi.com

# Atlassian account email (used as Basic-auth username).
[email protected]

# Atlassian API token (used as Basic-auth password).
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
EAZYBI_API_TOKEN=replace-me

# Optional: account ID to use when a tool is called without account_id.
# You can find it in the eazyBI URL after /accounts/ (e.g. 12345).
# EAZYBI_DEFAULT_ACCOUNT_ID=12345

# Optional: HTTP timeout in seconds (default 30).
# EAZYBI_HTTP_TIMEOUT=30

# ---- Other deployments ----------------------------------------------------
# eazyBI for Jira / Confluence Data Center:
#   EAZYBI_BASE_URL=https://your-jira.example.com/plugins/servlet/eazybi
#   EAZYBI_USER=jira-username
#   EAZYBI_API_TOKEN=jira-password-or-pat
#
# eazyBI.com (SaaS):
#   EAZYBI_BASE_URL=https://eazybi.com
#   EAZYBI_USER=your-eazybi-account-email
#   EAZYBI_API_TOKEN=your-eazybi-password
